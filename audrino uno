/* code to display the analog voltage input from arduino to LCD screen, 3 rows of input display

circuit:
  - LCD D4 to digital pin 5
  - LCD D5 to digital pin 4
  - LCD D6 to digital pin 3
  - LCD D7 to digital pin 2
  - LCD A to 5v input
  - LCD K to ground
  - LCD E to digital pin 11
  - LCD RW to ground
  - LCD RS to digital pin 12
  - LCD VO to output of potentiometer (this will control the brightness of the display)
  - LCD VDD to 5v input
  - LCD VSS to ground

*/

#include <LiquidCrystal.h>

LiquidCrystal lcd_1(12, 11, 5, 4, 3, 2); // the pins the LCD is connected to

void setup() { // put your setup code here, to run once:

  lcd_1.begin(16,3); // sets up the amount of columns and rows on the display

  lcd_1.print("hello world"); 
}

